# Required for Google Search (SerpAPI)
SERP_SEARCH_API_KEY=

# Required for NewsBytes LLM summarisation (free tier available at aistudio.google.com)
GEMINI_API_KEY=

# Optional — only needed if using the gpt-4o-mini model in NewsBytes
OPENAI_API_KEY=

# Required for Morning Brief (claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# Optional — Reddit User-Agent header (default: MorningBrief/1.0)
REDDIT_USER_AGENT=MorningBrief/1.0

# Optional — Morning Brief cache duration in ms (default: 6 hours)
MORNING_BRIEF_CACHE_TTL_MS=

# Optional — log verbosity: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# Optional — Semantic Scholar API key (unauthenticated = 100 req/5 min, sufficient for single user)
SEMANTIC_SCHOLAR_API_KEY=
